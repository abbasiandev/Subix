# Production / GitHub Pages build — set full backend URL before `npm run build`
# NEXT_PUBLIC_API_URL=https://subix.pythonanywhere.com

# Local dev — leave empty; API proxy handles requests (see pages/api/[...path].ts)
NEXT_PUBLIC_API_URL=
API_PROXY_TARGET=https://subix.pythonanywhere.com

# ── Local development ──────────────────────────────────────────────
# 1. npm run dev
# 2. Open http://localhost:3000/Subix/   (NOT http://localhost:3000/)
#
# npm run build + npm run preview = static export test (like GitHub Pages)
# npm run dev = daily development with live reload + API proxy
