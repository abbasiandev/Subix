# Telegram
BOT_TOKEN=your_bot_token_here
ENABLE_WEBHOOK=true
WEBHOOK_URL=https://subix.pythonanywhere.com/webhook
# Required on PythonAnywhere for /start (must be true in production .env)

# JWT
SECRET_KEY=change_this_to_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Turso
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_token_here

# App
APP_NAME=Subix
FRONTEND_URL=https://abbasiandev.github.io/Subix
DEBUG=false
